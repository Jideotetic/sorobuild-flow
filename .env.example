PORT=4307
SOROBUILD_FLOW_STORAGE=.storage/workflows
SOROBUILD_FLOW_TIMEOUT_MS=180000
SOROBUILD_FLOW_MAX_UPLOAD_MB=80
ALLOW_PROJECT_BUILD=false

# Cloudflare R2. If these are omitted, the API falls back to local filesystem storage.
R2_ACCOUNT_ID=
R2_BUCKET=sorobuild-flow
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# If true, local generated workflow folders are deleted after upload to R2.
# Keep false while testing so you can inspect generated files locally.
CLEAN_LOCAL_AFTER_R2=false
